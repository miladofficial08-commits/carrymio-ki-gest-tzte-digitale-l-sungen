# Professional mail sending configuration (used by Netlify functions)
# Preferred: set explicit SMTP values.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=mail@example.com
SMTP_PASS=your_mail_password_here
SMTP_FROM=Tawano <mail@example.com>
CONTACT_RECEIVER=mail@example.com

# Fallback: if only IMAP values are available, the code derives smtp.* from IMAP_HOST.
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_SECURE_SSL=true
IMAP_USER=mail@example.com
IMAP_PASS=your_mail_password_here

# Supabase Configuration
# Get these values from https://app.supabase.com/
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Retell Voice Agent Configuration (used by /api/call)
RETELL_API_KEY=your_retell_api_key_here
RETELL_FROM_NUMBER=+491234567890
RETELL_AGENT_TAWANO=agent_your_tawano_agent_id
