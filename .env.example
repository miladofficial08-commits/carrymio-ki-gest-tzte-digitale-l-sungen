VITE_EMAILJS_SERVICE_ID=your_service_id_here
VITE_EMAILJS_TEMPLATE_ID=your_internal_notification_template_id
VITE_EMAILJS_AUTORESPONSE_TEMPLATE_ID=your_autoresponse_template_id
