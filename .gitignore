# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Environment variables (keep private, do not commit)
.env
.env.local
.env.*.local

node_modules

# Vite build artifacts (but keep dist/src/** which is the actual source)
dist-ssr
*.local

# Keep dist/src and dist/index.html (source code and HTML template)
# But ignore compiled JavaScript and other build output in dist root
dist/*.js
dist/*.css
dist/*.json
dist/manifest.json
!dist/src/**

# Netlify function build artifacts
netlify/functions/*.zip
netlify/functions/manifest.json

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
